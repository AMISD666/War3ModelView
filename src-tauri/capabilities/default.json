{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": [
        "main"
    ],
    "permissions": [
        "fs:default",
        "fs:allow-read-text-file",
        "fs:allow-read-file",
        "fs:allow-write-file",
        "fs:allow-write-text-file",
        "dialog:default",
        "shell:allow-open",
        {
            "identifier": "http:default",
            "allow": [
                {
                    "url": "https://gitee.com/**"
                }
            ]
        },
        "core:webview:allow-internal-toggle-devtools",
        "core:event:default",
        "core:app:allow-version",
        "core:path:default",
        "process:allow-exit",
        {
            "identifier": "fs:scope",
            "allow": [
                "$HOME/**",
                "C:/**",
                "D:/**",
                "E:/**",
                "F:/**"
            ]
        }
    ]
}