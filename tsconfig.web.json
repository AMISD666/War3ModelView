{
    "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
    "include": [
        "src/renderer/src/**/*",
        "src/preload/*.d.ts",
        "src/env.d.ts",
        "vendor/war3-model/dist/war3-model.d.ts"
    ],
    "compilerOptions": {
        "composite": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "skipLibCheck": true,
        "types": [
            "@webgpu/types"
        ],
        "paths": {
            "@renderer/*": [
                "src/renderer/src/*"
            ],
            "war3-model": [
                "vendor/war3-model/dist/war3-model.d.ts"
            ]
        }
    }
}
