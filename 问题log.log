}

.node-manager-tree .ant-tree-indent-unit {
    width: 16px;
}

/* Ensure global drag isn't disabled for draggable elements */
[draggable="true"] {
    -webkit-user-drag: element;
    cursor: grab;
}

/* Dark Theme Overrides for Ant Design Modal Components */
.dark-theme-modal .ant-modal-content,
.dark-theme-modal .ant-modal-header,
.dark-theme-modal .ant-modal-body,
